# --- Required ---
OPENAI_API_KEY=sk-your-openai-key-here

# --- Optional: full pipeline only ---
ANTHROPIC_API_KEY=
PUSHOVER_USER=
PUSHOVER_TOKEN=

# --- Modal-hosted fine-tuned LLM (only if you deploy pricer_service.py) ---
HF_USER=
HF_PROJECT_NAME=price
HF_RUN_NAME=
HF_REVISION=

# --- Optional: choose preprocessor model (default: ollama/llama3.2) ---
PRICER_PREPROCESSOR_MODEL=ollama/llama3.2
